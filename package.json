{
  "name": "electron-app",
  "version": "0.1.0",
  "main": "electron/main.js",
  "scripts": {
    "start:react": "npm --prefix app run dev",
    "start:electron": "wait-on http://localhost:5173 && electron .",
    "dev": "concurrently -k \"npm run start:react\" \"npm run start:electron\"",
    "build": "npm --prefix app run build",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "verify": "node scripts/verify.js",
    "test": "jest",
    "postinstall": "cd app && npm install"
  },
  "dependencies": {
    "electron": "^36.5.0",
    "electron-log": "^5.4.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@types/testing-library__react": "^10.0.1",
    "concurrently": "^9.1.2",
    "electron-builder": "^26.0.12",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.0.2",
    "jest-environment-jsdom": "^30.0.2",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.virtualairline.vastats",
    "productName": "VA Stats",
    "directories": {
      "buildResources": "assets"
    },
    "files": [
      "electron/**/*",
      "app/dist/**/*",
      "node_modules/**/*"
    ],
    "linux": {
      "target": "AppImage"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
